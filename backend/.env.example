# AyuAahar Backend Environment Variables

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ayuaahar

# JWT Secret Key (change in production)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=True

# CORS Origins (comma-separated)
CORS_ORIGINS=https://ayu-adhar.vercel.app/
